MT5_LOGIN=00000000
MT5_PASSWORD=your-demo-password
MT5_SERVER=YourBroker-Demo

STRATEGY=v12_hybrid_adaptive_swing
MODE=READ_ONLY
SYMBOL=GBPUSD
SYMBOLS=GBPUSD,EURUSD,GBPJPY

# Global account-level controls.
MAX_OPEN_POSITIONS=3
MAX_OPEN_RISK_PERCENT=1.00
ALIGNED_GBP_RISK_CAP_PERCENT=0.90
MIXED_GBP_RISK_CAP_PERCENT=0.65
V12_MAX_SYMBOL_RISK_PERCENT=0.75

# V10 GBPUSD precision risk tiers.
V12_GBPUSD_PRIMARY_A_RISK=0.50
V12_GBPUSD_PRIMARY_B_RISK=0.20
V12_GBPUSD_SECONDARY_RISK=0.40
V12_GBPUSD_PULLBACK_RISK=0.40
GBPUSD_SWING_RISK_A=0.50
GBPUSD_SWING_RISK_B=0.20

# Existing satellites.
GBPUSD_SATELLITE_RISK=0.30
EURUSD_RISK=0.35
GBPJPY_RISK=0.35

# Adaptive guard.
V12_GUARD_ROLLING_TRADES=12
V12_GUARD_MINIMUM_TRADES=12
V12_GUARD_FULL_PF=1.15
V12_GUARD_FULL_NET_R=0.0
V12_GUARD_REDUCED_PF=0.90
V12_GUARD_REDUCED_NET_R=-1.20
V12_GUARD_REDUCED_MULTIPLIER=0.50
V12_GUARD_COOLDOWN_DAYS=60
V12_GUARD_PROBE_MULTIPLIER=0.50
V12_PROTECTED_ENGINES=GBPUSD_V10_PRECISION,GBPUSD_SWING_RETEST,GBPJPY_SWING_RETEST,EURUSD_SWING_CORE,GBPJPY_SWING_CORE
V12_STATE_PATH=state/v12_hybrid_adaptive_state.json

MAX_SPREAD_GBPUSD=2.0
MAX_SPREAD_EURUSD=1.5
MAX_SPREAD_GBPJPY=3.5
MAX_SLIPPAGE_POINTS=20
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500
DB_PATH=v12_live_journal.db

WRITE_DASHBOARD=true
SERVE_DASHBOARD=true
DASHBOARD_PORT=8801
DASHBOARD_REFRESH_SECONDS=1
LOOP_INTERVAL_SECONDS=1
