# Merge these values into your existing .env. Preserve private MT5 credentials.
SYMBOL=GBPUSD
STRATEGY=gbpusd_v4_satellite

# Start safely. Move to APPROVAL only after READ_ONLY verification.
MODE=READ_ONLY

# Frozen V4 swing risk.
RISK_BASED_SIZING=true
RISK_PERCENT=0.35
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

# One V4 swing plus one same-direction satellite position maximum.
MAX_OPEN_POSITIONS=2
MAX_SAME_DIRECTION=2
MIN_SAME_DIRECTION=1
MULTI_BOOK=false
TRAIL_ENABLED=false

# Shared $5,000 account limits.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# V4 + satellite portfolio controls.
SATELLITE_RISK_PERCENT=0.12
PORTFOLIO_MAX_RISK_PERCENT=0.50
V4_STATE_PATH=v4_state.json
SATELLITE_STATE_PATH=satellite_state.json

# Current official FOMC subset. This is not a complete GBP/USD macro calendar.
V4_NEWS_FILE=research/validation/official_fomc_events_live_2026.csv
V4_REQUIRE_NEWS_FILE=true

LOOP_INTERVAL_SECONDS=5
WRITE_DASHBOARD=true
DASHBOARD_PORT=8800
