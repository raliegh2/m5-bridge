# Merge these values into your existing .env. Preserve private MT5 credentials.
SYMBOL=GBPUSD
STRATEGY=gbpusd_v4_satellite_v2
MODE=READ_ONLY

# Frozen V4 swing risk.
RISK_BASED_SIZING=true
RISK_PERCENT=0.35
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

# One V4 swing plus one same-direction Satellite V2 position maximum.
MAX_OPEN_POSITIONS=2
MAX_SAME_DIRECTION=2
MIN_SAME_DIRECTION=1
MULTI_BOOK=false
TRAIL_ENABLED=false

# Shared $5,000 account loss limits.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# Satellite V2 sizing and portfolio limits.
# The engine requests up to 0.08 lots but clips size so one trade risks no more
# than 0.25% and combined open/new daily risk remains no more than 0.50%.
SATELLITE_V2_BASE_LOT=0.08
PORTFOLIO_V2_STATE_PATH=portfolio_v2_state.json
V4_STATE_PATH=v4_state.json

# Current official FOMC subset. Complete GBP/USD macro coverage is still needed.
V4_NEWS_FILE=research/validation/official_fomc_events_live_2026.csv
V4_REQUIRE_NEWS_FILE=true

LOOP_INTERVAL_SECONDS=5
WRITE_DASHBOARD=true
DASHBOARD_PORT=8800
