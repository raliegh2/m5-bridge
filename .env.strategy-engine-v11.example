# Strategy Engine V11 intraday-only research/demo profile
# Merge these values into your existing .env while preserving private MT5 credentials.

SYMBOL=GBPUSD
STRATEGY=strategy_engine_v11
MODE=READ_ONLY

# V11 is strictly intraday/day-trading only. Do not enable swing engines,
# overnight holds, or unattended live execution until the walk-forward,
# broker-native and forward-demo gates in research/V11_INTRADAY_BUILD_REPORT.md pass.

INTRADAY_ONLY=true
ALLOW_OVERNIGHT_POSITIONS=false
FORCE_FLAT_HOUR_UTC=20

RISK_BASED_SIZING=true
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

# Portfolio limits for the $5,000 research account.
MAX_OPEN_POSITIONS=3
MAX_OPEN_RISK_PERCENT=0.90
ALIGNED_GBP_CAP_PERCENT=0.60
MIXED_GBP_CAP_PERCENT=0.45
DAILY_NEW_RISK_PERCENT=0.75
MAX_RISK_PER_TRADE_PERCENT=0.40

# Enabled V11 intraday engines only.
ENABLE_GBPUSD_SATELLITE_V3=true
ENABLE_EURUSD_SATELLITE_V7=true
ENABLE_GBPJPY_SATELLITE_V7=true
ENABLE_GBPUSD_SWING_V6=false
DISABLE_SWING_ENGINES=true

# Quality-scored admission thresholds.
V11_QUALITY_THRESHOLD=0.62
V11_STRONG_QUALITY_THRESHOLD=0.74
V11_EXCEPTIONAL_QUALITY_THRESHOLD=0.84

# Walk-forward validation gates.
V11_MINIMUM_OOS_PROFIT_FACTOR=1.40
V11_MINIMUM_WALK_FORWARD_PASS_RATE=0.70
V11_MINIMUM_SETUP_TRADES_FOR_PROMOTION=30

# Loss guards.
REALIZED_DRAWDOWN_LIMIT_PERCENT=6.0
PAUSE_DRAWDOWN_PERCENT=10.0
LOSS_CUT_RISK_MULTIPLIER=0.50
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# Existing V9/V10 state and safety controls should remain active for intraday engines.
V9_EVENT_CALENDAR=research/validation/official_fomc_events_live_2026.csv
V9_EVAL_CACHE_SECONDS=10
V4_REQUIRE_NEWS_FILE=true

# Dashboard/debugging.
WRITE_DASHBOARD=true
DASHBOARD_PORT=8800
LOOP_INTERVAL_SECONDS=5
