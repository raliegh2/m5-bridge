MT5_LOGIN=00000000
MT5_PASSWORD=your-demo-password
MT5_SERVER=YourBroker-Demo

STRATEGY=v11_multisymbol_swing
MODE=READ_ONLY
SYMBOL=GBPUSD
SYMBOLS=GBPUSD,EURUSD,GBPJPY

# Existing V10 total account limits shared by satellites and swing engines.
MAX_OPEN_POSITIONS=3
MAX_OPEN_RISK_PERCENT=0.75
ALIGNED_GBP_RISK_CAP_PERCENT=0.75
MIXED_GBP_RISK_CAP_PERCENT=0.50

# V11 swing sub-portfolio limits frozen in the multi-window backtest.
V11_SWING_MAX_POSITIONS=3
V11_SWING_MAX_OPEN_RISK_PERCENT=0.50
V11_SWING_MAX_SYMBOL_RISK_PERCENT=0.35
V11_SWING_ALIGNED_GBP_CAP_PERCENT=0.50
V11_SWING_MIXED_GBP_CAP_PERCENT=0.35
V11_SWING_STATE_PATH=state/v11_multisymbol_swing_state.json

# V10 satellite risks remain available under the same global gate.
GBPUSD_SATELLITE_RISK=0.30
EURUSD_RISK=0.35
GBPJPY_RISK=0.35

# V11 uses fixed, unique strategy magic numbers in the 61001-63002 range.

MAX_SPREAD_GBPUSD=2.0
MAX_SPREAD_EURUSD=1.5
MAX_SPREAD_GBPJPY=3.5
MAX_SLIPPAGE_POINTS=20

DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500
DB_PATH=v11_live_journal.db
WRITE_DASHBOARD=true
SERVE_DASHBOARD=true
DASHBOARD_PORT=8801
DASHBOARD_REFRESH_SECONDS=1
LOOP_INTERVAL_SECONDS=1
