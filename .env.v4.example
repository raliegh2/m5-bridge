# Copy these values into your existing .env. Keep your private MT5 credentials.
SYMBOL=GBPUSD
STRATEGY=gbpusd_v4

# Start safely. Move to APPROVAL only after READ_ONLY behaves correctly.
MODE=READ_ONLY

# 0.35 means 0.35% of current balance per trade.
RISK_BASED_SIZING=true
RISK_PERCENT=0.35
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

# V4 permits only one GBPUSD position and bypasses the legacy books.
MAX_OPEN_POSITIONS=1
MAX_SAME_DIRECTION=1
MIN_SAME_DIRECTION=1
MULTI_BOOK=false
TRAIL_ENABLED=false

# $5,000 High Stakes limits. Verify against the exact account rules.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# Live event file. This repository currently contains an official FOMC subset,
# not a complete GBP/USD macro calendar.
V4_NEWS_FILE=research/validation/official_fomc_events_2016_2026.csv
V4_REQUIRE_NEWS_FILE=true
V4_STATE_PATH=v4_state.json

LOOP_INTERVAL_SECONDS=5
