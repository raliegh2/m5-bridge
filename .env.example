# =====================================================================
#  BALANCED REAL-USE PROFILE (swing-led, trend-aligned, ATR stops,
#  fixed-fractional sizing). No settings guarantee profit -- validate
#  on YOUR data: Export History.bat -> python -m mt5_ai_bridge.backtest_books
# =====================================================================

MT5_LOGIN=00000000
MT5_PASSWORD=your-demo-password
MT5_SERVER=YourBroker-Demo

SYMBOL=GBPUSD
# Trade MANY pairs at once on ONE account: set SYMBOLS to a comma/space list
# (e.g. "GBPUSD, GBPJPY, USDJPY"). Leave blank to trade just SYMBOL above.
# All pairs share the account's risk limits below; the COMBINED_RISK_CEILING
# caps total open risk across every pair so portfolio drawdown stays in the
# same envelope as trading one pair (diversification adds return, not risk).
# Validated set (each pair on its working engine): GBPUSD, GBPJPY, USDJPY,
# EURUSD (day-led), AUDUSD (day-only), XAUUSD (gold, low-risk). Example:
#   SYMBOLS=GBPUSD, GBPJPY, USDJPY, EURUSD, AUDUSD, XAUUSD
SYMBOLS=
# Fast entry chart. Higher charts below confirm the direction.
TIMEFRAME=M15
# MODE: AUTO = trade automatically; APPROVAL = ask before each trade;
# READ_ONLY = observe/journal only, never trade.
MODE=AUTO
# SAFETY: with REQUIRE_DEMO=true the bot REFUSES to auto-trade a REAL (live)
# account -- it only places trades on a demo. Set false to override (NOT advised).
REQUIRE_DEMO=true

# PROP-FIRM CHALLENGE MODE (FTMO-style drawdown protection). When PROP_FIRM=true
# the bot tracks the challenge start balance + equity peak and: blocks new trades
# if the daily-loss or max-drawdown limit is hit, stops trading once the profit
# target is reached (to lock the pass), and SCALES per-trade risk down as it
# approaches a limit. PROP_START_BALANCE=0 auto-captures your balance on first run.
# You can also flip this ON/OFF live from the dashboard's Prop challenge panel.
PROP_FIRM=false
PROP_START_BALANCE=0
PROP_MAX_DAILY_LOSS_PCT=5
PROP_MAX_TOTAL_LOSS_PCT=10
PROP_PROFIT_TARGET_PCT=8
PROP_TRAILING=false
PROP_DERISK_START_PCT=60

# REGIME ROUTER (Efficiency Ratio) -- OPT-IN, OFF by default. When REGIME_FILTER=true
# the trend engines only open NEW trades in a DIRECTIONAL regime: Kaufman
# Efficiency Ratio ER(20) on the entry chart >= REGIME_ER_MIN. In a RANGE regime
# (choppy, ER below the threshold) the bot stands aside -- that is where a trend
# follower is most vulnerable to repeated stop-outs. Per-symbol override example:
# REGIME_ER_MIN_XAUUSD=0.35
REGIME_FILTER=false
REGIME_ER_MIN=0.30

# CURRENCY-FACTOR EXPOSURE CAPS -- ON by default (risk control, not alpha).
# A book that looks diversified by SYMBOL can be one bet by CURRENCY: long
# EURUSD + AUDUSD + XAUUSD are ALL short USD, so a dollar rally hits every leg.
FACTOR_CAPS=true
MAX_CURRENCY_RISK=2.0

STRATEGY=reasoning
REASONING_THRESHOLD=0.6
RSI_OVERBOUGHT=75
RSI_OVERSOLD=25

# Volatility-adaptive stops: stop = ATR x mult.
ATR_ENABLED=true
ATR_PERIOD=14
ATR_SL_MULT=2.0
ATR_TP_MULT=4.0
ATR_MIN_SL_PIPS=8
ATR_MAX_SL_PIPS=200

# Fixed-fractional sizing: lot size is derived from account balance, the engine's
# risk percentage, symbol tick value and the actual stop distance.
RISK_BASED_SIZING=true
COMBINED_RISK_CEILING=2.5
RISK_PERCENT=0.5
INTRADAY_RISK_PERCENT=0.11
SWING_RISK_PERCENT=1.05
# Optional per-symbol engine allocations:
# SWING_RISK_PERCENT_GBPUSD=1.05
# SWING_RISK_PERCENT_GBPJPY=0.9
# SWING_RISK_PERCENT_USDJPY=0.65
# SWING_RISK_PERCENT_EURUSD=0.35
# INTRADAY_RISK_PERCENT_EURUSD=0.30
# SWING_RISK_PERCENT_AUDUSD=0
# INTRADAY_RISK_PERCENT_AUDUSD=0.30
# Gold ships throttled in code (swing 0.2%, intraday 0.1%). Override only after
# testing with your broker's XAUUSD contract/tick values:
# SWING_RISK_PERCENT_XAUUSD=0.2
# INTRADAY_RISK_PERCENT_XAUUSD=0.1
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0
LOT_SIZE=0.09
NY_SIZE_MULTIPLIER=2.0
NY_START_HOUR=12
NY_END_HOUR=21

# Multi-timeframe books: M15/M30 intraday and H4/D1 swing work together.
MULTI_BOOK=true
REQUIRE_TREND_ALIGNMENT=true
TREND_TF_MID=M30
SWING_TF_HIGH=H4
SWING_TF_HIGHER=D1
SWING_STRONG_MAX=2
DAY_TIMEFRAME=M15
DAY_SL_PIPS=15
DAY_TP_PIPS=30
DAY_STRONG_MAX=1
SCALP_TIMEFRAME=M5
SCALP_SL_PIPS=8
SCALP_TP_PIPS=16
SCALP_STRONG_MAX=1

SWING_SL_PIPS=80
SWING_TP_PIPS=160
INTRADAY_SL_PIPS=20
INTRADAY_TP_PIPS=40
SWING_CONFIDENCE=0.7

STRONG_TREND_CONFIDENCE=0.8
MIN_SAME_DIRECTION=3
MAX_SAME_DIRECTION=7
TP_STAGGER_STEP=0.5
SL_STAGGER_STEP=0.25
SL_FLOOR_PIPS=10

TRAIL_ENABLED=true
TRAIL_START_PIPS=20
TRAIL_DISTANCE_PIPS=15

# Legacy dollar/account limits inside app.py.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500
MAX_OPEN_POSITIONS=7
MAX_TRADES_PER_DAY=20

# =====================================================================
#  PERSISTENT LIVE SESSION CIRCUIT BREAKERS
#
# These checks sit below BOTH the Gold/intraday and swing engines. They intercept
# every NEW entry request, while closes and trailing-stop updates remain allowed.
# State survives restarts in <DB_PATH stem>_session_guard.json.
# =====================================================================
SESSION_GUARD=true

# On a $5,000 account, 1% = $50. New entries remain locked until the next broker
# day. Existing positions continue to be managed unless close-on-stop is enabled.
SESSION_ENABLE_DAILY_LOSS_LIMIT=true
SESSION_MAX_DAILY_LOSS_PERCENT=1.0
SESSION_CLOSE_POSITIONS_ON_DAILY_STOP=false

# Activate after +1%. Once active, surrendering 40% of the session peak locks
# new entries. Example: +$84 peak on $5,000 -> lock near +$50.40.
SESSION_ENABLE_PROFIT_GIVEBACK_STOP=true
SESSION_PROFIT_LOCK_ACTIVATION_PERCENT=1.0
SESSION_MAX_PROFIT_GIVEBACK_PERCENT=40
SESSION_CLOSE_POSITIONS_ON_PROFIT_STOP=false

# Net result includes profit + commission + swap + fees. Partial closes are not
# counted until the full MT5 position_id has closed.
SESSION_ENABLE_CONSECUTIVE_LOSS_STOP=true
SESSION_MAX_CONSECUTIVE_LOSSES=3
SESSION_LOSS_COOLDOWN_MINUTES=60
SESSION_STOP_FOR_DAY_AFTER_LOSS_LIMIT=true

# Account-wide and per-symbol entry throttles shared by both engines.
SESSION_ENABLE_TRADE_LIMIT=true
SESSION_MAX_TRADES_PER_DAY=8
SESSION_MAX_TRADES_PER_SYMBOL_PER_DAY=4
SESSION_MINIMUM_MINUTES_BETWEEN_ENTRIES=15

# Final order-volume safety gate, independent of ATR/fixed-fractional sizing.
# This rejects rather than silently resizing, so the journal remains accurate.
SESSION_MINIMUM_LOT=0.01
SESSION_MAXIMUM_LOT=0.40

# Pending orders belonging to this bot are cancelled when a daily lock triggers.
SESSION_CANCEL_PENDING_ON_STOP=true
SESSION_HISTORY_SYNC_SECONDS=2
SESSION_HISTORY_LOOKBACK_DAYS=30
# SESSION_STATE_PATH=C:\path\to\session_guard_state.json

WRITE_DASHBOARD=true
DASHBOARD_PATH=dashboard.html
DASHBOARD_REFRESH_SECONDS=1
SERVE_DASHBOARD=true
DASHBOARD_PORT=8800
DASHBOARD_HOST=127.0.0.1
CONSOLE_STATUS=true

# How often the bot re-reads the market, refreshes the dashboard, and trails
# stops. Raise to 3 seconds if your broker connection gets chatty.
LOOP_INTERVAL_SECONDS=1
LOG_LEVEL=INFO
DB_PATH=journal.db
RECONNECT_ATTEMPTS=3
RECONNECT_DELAY_SECONDS=5
