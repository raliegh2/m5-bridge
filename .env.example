# =====================================================================
#  BALANCED REAL-USE PROFILE (swing-led, trend-aligned, ATR stops,
#  fixed-fractional 1-2% sizing). No settings guarantee profit -- validate
#  on YOUR data: Export History.bat -> python -m mt5_ai_bridge.backtest_books
# =====================================================================

MT5_LOGIN=00000000
MT5_PASSWORD=your-demo-password
MT5_SERVER=YourBroker-Demo

SYMBOL=GBPUSD
# Fast entry chart. Higher charts below confirm the direction.
TIMEFRAME=M15
MODE=AUTO

STRATEGY=reasoning
REASONING_THRESHOLD=0.6
RSI_OVERBOUGHT=75
RSI_OVERSOLD=25

# Volatility-adaptive stops: stop = ATR x mult (day/scalp ~1.5-2x, swing ~2-3x).
ATR_ENABLED=true
ATR_PERIOD=14
ATR_SL_MULT=2.0
ATR_TP_MULT=4.0
ATR_MIN_SL_PIPS=8
ATR_MAX_SL_PIPS=200

# Fixed-fractional sizing (the "1-2% rule"): risk RISK_PERCENT of balance per
# trade, lot derived from the stop distance. IMPORTANT: set DAILY/TOTAL loss
# limits below as a % of your account to match (7 trades x RISK_PERCENT max).
RISK_BASED_SIZING=true
RISK_PERCENT=0.5
INTRADAY_RISK_PERCENT=0.15
SWING_RISK_PERCENT=0.35
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0
LOT_SIZE=0.09
NY_SIZE_MULTIPLIER=2.0
NY_START_HOUR=12
NY_END_HOUR=21

# Multi-timeframe books (swing-led, trend-aligned)
MULTI_BOOK=true
REQUIRE_TREND_ALIGNMENT=true
TREND_TF_MID=M30
SWING_TF_HIGH=H4
SWING_TF_HIGHER=D1
SWING_STRONG_MAX=2
DAY_TIMEFRAME=M15
DAY_SL_PIPS=15
DAY_TP_PIPS=30
DAY_STRONG_MAX=1
SCALP_TIMEFRAME=M5
SCALP_SL_PIPS=8
SCALP_TP_PIPS=16
SCALP_STRONG_MAX=1

SWING_SL_PIPS=80
SWING_TP_PIPS=160
INTRADAY_SL_PIPS=20
INTRADAY_TP_PIPS=40
SWING_CONFIDENCE=0.7

STRONG_TREND_CONFIDENCE=0.8
MIN_SAME_DIRECTION=3
MAX_SAME_DIRECTION=7
TP_STAGGER_STEP=0.5
SL_STAGGER_STEP=0.25
SL_FLOOR_PIPS=10

# Protective trade management.
# The app's current loop calls the trailing stop manager every cycle.
# The upgraded manager now also moves SL to break-even after roughly 1R and
# never loosens an existing stop. Keep these conservative until backtested.
TRAIL_ENABLED=true
TRAIL_START_PIPS=20
TRAIL_DISTANCE_PIPS=15

# Loss limits -- set to a % of your account (e.g. ~1-2% daily) so they match
# the per-trade risk above.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500
MAX_OPEN_POSITIONS=7
MAX_TRADES_PER_DAY=20

WRITE_DASHBOARD=true
DASHBOARD_PATH=dashboard.html
DASHBOARD_REFRESH_SECONDS=5
SERVE_DASHBOARD=true
DASHBOARD_PORT=8800
DASHBOARD_HOST=127.0.0.1
CONSOLE_STATUS=true

LOOP_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
DB_PATH=journal.db
RECONNECT_ATTEMPTS=3
RECONNECT_DELAY_SECONDS=5
