# =====================================================================
#  BALANCED REAL-USE PROFILE (swing-led, trend-aligned, ATR stops,
#  fixed-fractional 1-2% sizing). No settings guarantee profit -- validate
#  on YOUR data: Export History.bat -> python -m mt5_ai_bridge.backtest_books
# =====================================================================

MT5_LOGIN=00000000
MT5_PASSWORD=your-demo-password
MT5_SERVER=YourBroker-Demo

SYMBOL=GBPUSD
# Trade MANY pairs at once on ONE account: set SYMBOLS to a comma/space list
# (e.g. "GBPUSD, GBPJPY, USDJPY"). Leave blank to trade just SYMBOL above.
# All pairs share the account's risk limits below; the COMBINED_RISK_CEILING
# caps total open risk across every pair so portfolio drawdown stays in the
# same envelope as trading one pair (diversification adds return, not risk).
# Validated set (each pair on its working engine): GBPUSD, GBPJPY, USDJPY,
# EURUSD (day-led), AUDUSD (day-only), XAUUSD (gold, low-risk). Example:
#   SYMBOLS=GBPUSD, GBPJPY, USDJPY, EURUSD, AUDUSD, XAUUSD
SYMBOLS=
# Fast entry chart. Higher charts below confirm the direction.
TIMEFRAME=M15
# MODE: AUTO = trade automatically; APPROVAL = ask before each trade;
# READ_ONLY = observe/journal only, never trade.
MODE=AUTO
# SAFETY: with REQUIRE_DEMO=true the bot REFUSES to auto-trade a REAL (live)
# account -- it only places trades on a demo. Set false to override (NOT advised).
REQUIRE_DEMO=true

# PROP-FIRM CHALLENGE MODE (FTMO-style drawdown protection). When PROP_FIRM=true
# the bot tracks the challenge start balance + equity peak and: blocks new trades
# if the daily-loss or max-drawdown limit is hit, stops trading once the profit
# target is reached (to lock the pass), and SCALES per-trade risk down as it
# approaches a limit. PROP_START_BALANCE=0 auto-captures your balance on first run.
# You can also flip this ON/OFF live from the dashboard's Prop challenge panel.
PROP_FIRM=false
PROP_START_BALANCE=0
PROP_MAX_DAILY_LOSS_PCT=5
PROP_MAX_TOTAL_LOSS_PCT=10
PROP_PROFIT_TARGET_PCT=8
PROP_TRAILING=false
PROP_DERISK_START_PCT=60

STRATEGY=reasoning
REASONING_THRESHOLD=0.6
RSI_OVERBOUGHT=75
RSI_OVERSOLD=25

# Volatility-adaptive stops: stop = ATR x mult (day/scalp ~1.5-2x, swing ~2-3x).
ATR_ENABLED=true
ATR_PERIOD=14
ATR_SL_MULT=2.0
ATR_TP_MULT=4.0
ATR_MIN_SL_PIPS=8
ATR_MAX_SL_PIPS=200

# Fixed-fractional sizing (the "1-2% rule"): risk RISK_PERCENT of balance per
# trade, lot derived from the stop distance. IMPORTANT: set DAILY/TOTAL loss
# limits below as a % of your account to match (7 trades x RISK_PERCENT max).
# Swing-led allocation: the H4 swing engine has far higher per-trade edge than
# the M15 day engine, so it carries the larger risk fraction. Scale BOTH down
# proportionally for smaller accounts / tighter drawdown.
RISK_BASED_SIZING=true
# Max AGGREGATE open risk (%% of balance) across ALL pairs and both engines.
# With one pair, worst-case open risk is ~2.2%%; 2.5%% keeps the multi-pair book
# in the same drawdown envelope. Raise toward 3.5%% for more return (and more
# drawdown, up to the governor); lower for a tighter account.
COMBINED_RISK_CEILING=2.5
RISK_PERCENT=0.5
INTRADAY_RISK_PERCENT=0.11
SWING_RISK_PERCENT=1.05
# PER-SYMBOL RISK OVERRIDES (optional). Append a symbol to either name to give
# that pair its own risk %; anything unset uses the globals above. Backtests
# show pairs split into two profiles -- set each pair to its stronger engine so
# ALL pairs contribute (validate on your own data before funded use):
#   SWING-LED (elite H4 swing engine) -- keep swing high, day low:
#     SWING_RISK_PERCENT_GBPUSD=1.05
#     SWING_RISK_PERCENT_GBPJPY=0.9
#     SWING_RISK_PERCENT_USDJPY=0.65
#   DAY-LED (edge is in the M15 day engine; swing is weak) -- flip it so the
#   day engine carries the pair:
#     SWING_RISK_PERCENT_EURUSD=0.35
#     INTRADAY_RISK_PERCENT_EURUSD=0.30
#   DAY-ONLY (swing side LOSES out-of-sample) -- set its swing risk to 0 to
#   DISABLE that engine and keep only the profitable day engine:
#     SWING_RISK_PERCENT_AUDUSD=0
#     INTRADAY_RISK_PERCENT_AUDUSD=0.30
#   GOLD / XAUUSD ships THROTTLED BY DEFAULT (built into the code: swing 0.2%%,
#   intraday 0.1%%) because gold moves far more per lot than FX and whipsaws in
#   ranges -- so it cannot dominate drawdown out of the box. Uncomment to tune
#   or set either to 0 to disable that engine for gold:
#     SWING_RISK_PERCENT_XAUUSD=0.2
#     INTRADAY_RISK_PERCENT_XAUUSD=0.1
# Setting either risk to 0 DISABLES that engine for the symbol.
# PIP_VALUE_PER_LOT is now auto-derived per symbol from the broker's tick data
# (correct for JPY pairs too); the value below is only a fallback if the broker
# doesn't report tick_value/tick_size.
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0
LOT_SIZE=0.09
NY_SIZE_MULTIPLIER=2.0
NY_START_HOUR=12
NY_END_HOUR=21

# Multi-timeframe books (swing-led, trend-aligned)
MULTI_BOOK=true
REQUIRE_TREND_ALIGNMENT=true
TREND_TF_MID=M30
SWING_TF_HIGH=H4
SWING_TF_HIGHER=D1
SWING_STRONG_MAX=2
DAY_TIMEFRAME=M15
DAY_SL_PIPS=15
DAY_TP_PIPS=30
DAY_STRONG_MAX=1
SCALP_TIMEFRAME=M5
SCALP_SL_PIPS=8
SCALP_TP_PIPS=16
SCALP_STRONG_MAX=1

SWING_SL_PIPS=80
SWING_TP_PIPS=160
INTRADAY_SL_PIPS=20
INTRADAY_TP_PIPS=40
SWING_CONFIDENCE=0.7

STRONG_TREND_CONFIDENCE=0.8
MIN_SAME_DIRECTION=3
MAX_SAME_DIRECTION=7
TP_STAGGER_STEP=0.5
SL_STAGGER_STEP=0.25
SL_FLOOR_PIPS=10

TRAIL_ENABLED=true
TRAIL_START_PIPS=20
TRAIL_DISTANCE_PIPS=15

# Loss limits -- set to a % of your account (e.g. ~1-2% daily) so they match
# the per-trade risk above.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500
MAX_OPEN_POSITIONS=7
MAX_TRADES_PER_DAY=20

WRITE_DASHBOARD=true
DASHBOARD_PATH=dashboard.html
# How often the dashboard refreshes itself in place (seconds).
DASHBOARD_REFRESH_SECONDS=1
SERVE_DASHBOARD=true
DASHBOARD_PORT=8800
DASHBOARD_HOST=127.0.0.1
CONSOLE_STATUS=true

LOOP_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
DB_PATH=journal.db
RECONNECT_ATTEMPTS=3
RECONNECT_DELAY_SECONDS=5
