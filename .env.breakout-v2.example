# GBPUSD breakout v2 — proxy-validated conservative defaults
SYMBOL=GBPUSD
STRATEGY=gbpusd_breakout_v2

# Start with APPROVAL or READ_ONLY. Do not switch to unattended execution
# until demo-forward results match the proxy assumptions.
MODE=APPROVAL

# 0.5 means 0.50% of balance risked per trade.
RISK_BASED_SIZING=true
RISK_PERCENT=0.5
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

# The dedicated engine allows one GBPUSD position and bypasses legacy books.
MAX_OPEN_POSITIONS=1
MAX_SAME_DIRECTION=1
MIN_SAME_DIRECTION=1
MULTI_BOOK=false

# Shared account-level circuit breakers. For a $5,000 5ers account these are
# $250 daily and $500 total. Adjust only to the exact account rules.
DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# Generic trailing is bypassed by the dedicated engine; it uses 2.5 H4 ATR
# after the trade reaches 1R.
TRAIL_ENABLED=false

# Keep the loop responsive; new entries remain completed-H4 only.
LOOP_INTERVAL_SECONDS=5
