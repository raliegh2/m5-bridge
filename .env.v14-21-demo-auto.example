# V14.21 DEMO-ONLY AUTOMATIC RUNNER
#
# Copy this file to .env and replace placeholders locally.
# Never commit real MT5 credentials.

MT5_LOGIN=YOUR_DEMO_LOGIN
MT5_PASSWORD=YOUR_DEMO_PASSWORD
MT5_SERVER=YOUR_DEMO_SERVER

# Safe default. Validate READ_ONLY first.
V14_21_EXECUTION_MODE=READ_ONLY

# Pin the exact demo account that may receive orders.
V14_21_EXPECTED_LOGIN=YOUR_DEMO_LOGIN
V14_21_EXPECTED_SERVER=YOUR_DEMO_SERVER

# All three lines are mandatory before DEMO_AUTO is accepted.
V14_21_FORWARD_GATE_PASSED=false
V14_21_ALLOW_DEMO_AUTO=false
V14_21_ACKNOWLEDGE_DEMO_ONLY=

# After READ_ONLY and demo-forward verification:
# V14_21_EXECUTION_MODE=DEMO_AUTO
# V14_21_FORWARD_GATE_PASSED=true
# V14_21_ALLOW_DEMO_AUTO=true
# V14_21_ACKNOWLEDGE_DEMO_ONLY=DEMO_ONLY

V14_21_STATE_PATH=state/v14_21_demo_auto_state.json
V14_21_AUDIT_LOG_PATH=state/v14_21_demo_auto_executions.jsonl
V14_21_KILL_SWITCH_PATH=state/V14_21_STOP

# Retained account limits.
V14_21_DAILY_LOSS_LIMIT_DOLLARS=250
V14_21_OVERALL_LOSS_LIMIT_DOLLARS=500
V14_21_MAX_CONSECUTIVE_LOSSES=2

# Operational guards.
V14_21_MAX_TICK_AGE_SECONDS=10
V14_21_MAX_SIGNAL_AGE_MINUTES=90
V14_21_MAX_DEVIATION_POINTS=10

# Optional: pin the total-loss baseline. Zero captures demo balance on first run.
V14_21_INITIAL_BALANCE=0

# Existing V14.4 live-profit guards remain active.
V14_4_MAX_SPREAD_FRACTION_OF_STOP=0.10
V14_4_MAX_M1_SIGNAL_AGE_MINUTES=5
V14_4_DAILY_LOSS_STOP_PERCENT=1.50

# Existing GBP M1 provider.
V14_3_LEGACY_GBP_ICT_PROVIDER=v14_3_signals_research_parity
