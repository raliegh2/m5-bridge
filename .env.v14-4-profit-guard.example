# V14.4 profit-guarded research-parity live runner.
# Start with READ_ONLY after any change; switch to AUTO only on demo with
# both gates set, exactly as with V14.3.

V14_3_EXECUTION_MODE=READ_ONLY
V14_3_FORWARD_GATE_PASSED=false
V14_3_ALLOW_DEMO_AUTO=false
V14_3_LIVE_STATE_PATH=state/v14_4_profit_guard_live_state.json
V14_3_MAX_DEVIATION_POINTS=10
V14_3_MAX_SIGNAL_AGE_MINUTES=90

# --- V14.4 live profit guards (defaults shown) ---

# Reject an entry when live spread exceeds this fraction of the stop
# distance. 0.10 on a 5-pip stop allows at most 0.5 pips of spread.
V14_4_MAX_SPREAD_FRACTION_OF_STOP=0.10

# M1 scalp signals older than this are rejected (the shared 90-minute
# limit still applies to H1/H4 engines).
V14_4_MAX_M1_SIGNAL_AGE_MINUTES=5

# Stop opening new positions for the rest of the UTC day once equity is
# down this percent from day-start equity.
V14_4_DAILY_LOSS_STOP_PERCENT=1.50

# Per-setup live expectancy tiers over the last N closed trades:
#   cumulative R <= reduce threshold  -> risk x reduced multiplier
#   cumulative R <= observe threshold -> 0.025% observation risk only
V14_4_EXPECTANCY_WINDOW=20
V14_4_MIN_TRADES_BEFORE_REDUCTION=8
V14_4_REDUCE_THRESHOLD_R=-4.0
V14_4_REDUCED_RISK_MULTIPLIER=0.50
V14_4_OBSERVE_THRESHOLD_R=-8.0

# Days of broker deal history used to reconstruct the true balance peak
# when the state file is new or was reset.
V14_4_PEAK_RECONSTRUCTION_DAYS=120
