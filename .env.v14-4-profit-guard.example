# V14.13 cost-regime research-parity live runner.
# Start with READ_ONLY after any change. AUTO remains demo-only and requires
# both explicit gates exactly as in V14.3/V14.4.

V14_3_EXECUTION_MODE=READ_ONLY
V14_3_FORWARD_GATE_PASSED=false
V14_3_ALLOW_DEMO_AUTO=false
V14_3_LIVE_STATE_PATH=state/v14_4_profit_guard_live_state.json
V14_3_MAX_DEVIATION_POINTS=10
V14_3_MAX_SIGNAL_AGE_MINUTES=90

# --- V14.4 live profit guards ---
V14_4_MAX_SPREAD_FRACTION_OF_STOP=0.10
V14_4_MAX_M1_SIGNAL_AGE_MINUTES=5
V14_4_DAILY_LOSS_STOP_PERCENT=1.50
V14_4_EXPECTANCY_WINDOW=20
V14_4_MIN_TRADES_BEFORE_REDUCTION=8
V14_4_REDUCE_THRESHOLD_R=-4.0
V14_4_REDUCED_RISK_MULTIPLIER=0.50
V14_4_OBSERVE_THRESHOLD_R=-8.0
V14_4_PEAK_RECONSTRUCTION_DAYS=120

# --- V14.13 all-in cost reserves ---
# These are round-trip planning reserves, expressed in pips unless marked R.
# Replace them with conservative values for the actual broker/account type.
V14_13_COMMISSION_RESERVE_PIPS=0.10
V14_13_SLIPPAGE_RESERVE_PIPS=0.10
V14_13_NON_M1_SWAP_RESERVE_PIPS=0.20
V14_13_LATENCY_RESERVE_R=0.01

# Cost regime boundaries in initial-risk units.
# <=0.04R: low-cost parity; <=0.09R: medium-cost controls;
# <=0.18R: strict retail/stress subsets; above 0.18R: shadow only.
V14_13_PARITY_COST_R=0.04
V14_13_MEDIUM_COST_R=0.09
V14_13_MAXIMUM_SUPPORTED_COST_R=0.18
V14_13_MAXIMUM_COST_FRACTION_OF_TARGET=0.15
V14_13_OBSERVATION_RISK_PERCENT=0.025
