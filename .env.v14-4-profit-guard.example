# V14.12 net-positive after-cost research-parity live runner.
# Start with READ_ONLY after any change; switch to AUTO only on a confirmed
# demo account after forward validation and both explicit execution gates pass.

V14_3_EXECUTION_MODE=READ_ONLY
V14_3_FORWARD_GATE_PASSED=false
V14_3_ALLOW_DEMO_AUTO=false
# Keep this V14.4 path during the V14.12 upgrade so historical state, peak
# equity, processed positions, and live setup results are not reset.
V14_3_LIVE_STATE_PATH=state/v14_4_profit_guard_live_state.json
V14_3_MAX_DEVIATION_POINTS=10
V14_3_MAX_SIGNAL_AGE_MINUTES=90

# --- V14.4 inherited live profit guards ---

# Reject an entry when live spread exceeds this fraction of the stop distance.
V14_4_MAX_SPREAD_FRACTION_OF_STOP=0.10

# M1 scalp signals older than this are rejected. The shared 90-minute limit
# still applies to H1/H4 engines.
V14_4_MAX_M1_SIGNAL_AGE_MINUTES=5

# Stop opening new positions for the rest of the UTC day once equity is down
# this percent from day-start equity.
V14_4_DAILY_LOSS_STOP_PERCENT=1.50

# Legacy per-setup loss-demotion layer retained beneath V14.12.
V14_4_EXPECTANCY_WINDOW=20
V14_4_MIN_TRADES_BEFORE_REDUCTION=8
V14_4_REDUCE_THRESHOLD_R=-4.0
V14_4_REDUCED_RISK_MULTIPLIER=0.50
V14_4_OBSERVE_THRESHOLD_R=-8.0

# Days of broker deal history used to reconstruct the balance peak when the
# state file is new or was reset.
V14_4_PEAK_RECONSTRUCTION_DAYS=120

# --- V14.12 broker-net setup and symbol promotion gates ---

# Rolling closed-trade windows. R is calculated from broker-net cash P/L after
# commission, swap, and fees divided by the stored risk dollars.
V14_12_SETUP_WINDOW=30
V14_12_SYMBOL_WINDOW=60
V14_12_MINIMUM_SETUP_TRADES=12
V14_12_MINIMUM_SYMBOL_TRADES=20

# A historically promoted V12 setup begins at 25% of its V14.5.2 allocation.
# Positive but not full-strength evidence trades at 50%; weak evidence trades
# at the 0.025% observation tier. These multipliers never increase static risk.
V14_12_PROBATION_RISK_MULTIPLIER=0.25
V14_12_REDUCED_RISK_MULTIPLIER=0.50

# Both setup and symbol must exceed the positive floors. Full allocation also
# requires the stronger profit-factor and cumulative-net-R thresholds below.
V14_12_MINIMUM_POSITIVE_PROFIT_FACTOR=1.00
V14_12_MINIMUM_POSITIVE_NET_R=0.00
V14_12_FULL_SETUP_PROFIT_FACTOR=1.15
V14_12_FULL_SYMBOL_PROFIT_FACTOR=1.08
V14_12_FULL_SETUP_NET_R=1.00
V14_12_FULL_SYMBOL_NET_R=1.00

# Current spread is combined with these configurable allowances before entry.
# The trade is rejected if all-in cost consumes too much of its stop or target.
V14_12_COMMISSION_EQUIVALENT_PIPS=0.10
V14_12_SLIPPAGE_BUFFER_PIPS=0.10
V14_12_SWAP_RESERVE_PIPS=0.05
V14_12_MAX_ALL_IN_COST_FRACTION_OF_STOP=0.12
V14_12_MAX_ALL_IN_COST_FRACTION_OF_TARGET=0.08
