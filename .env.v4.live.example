# Merge these values into your existing .env. Preserve MT5 credentials.
SYMBOL=GBPUSD
STRATEGY=gbpusd_v4

# Start in READ_ONLY. Move to APPROVAL only after verification.
MODE=READ_ONLY

RISK_BASED_SIZING=true
RISK_PERCENT=0.35
PIP_VALUE_PER_LOT=10.0
MAX_LOT=2.0

MAX_OPEN_POSITIONS=1
MAX_SAME_DIRECTION=1
MIN_SAME_DIRECTION=1
MULTI_BOOK=false
TRAIL_ENABLED=false

DAILY_MAX_LOSS=250
TOTAL_MAX_LOSS=500

# Current official FOMC subset. This is not a complete GBP/USD macro calendar;
# manually check BoE, CPI, NFP and UK releases before APPROVAL-mode entries.
V4_NEWS_FILE=research/validation/official_fomc_events_live_2026.csv
V4_REQUIRE_NEWS_FILE=true
V4_STATE_PATH=v4_state.json

LOOP_INTERVAL_SECONDS=5
