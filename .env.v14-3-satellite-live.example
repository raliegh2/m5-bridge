# Copy these values into your existing .env. Never commit real credentials.
MT5_LOGIN=00000000
MT5_PASSWORD=replace_me
MT5_SERVER=Broker-Demo

# Fail-closed execution mode: READ_ONLY, APPROVAL, or AUTO.
V14_3_EXECUTION_MODE=READ_ONLY

# Default demo-forward-test risk cap. Values above 0.25 require the forward gate.
V14_3_LIVE_MAX_RISK_PERCENT=0.25
V14_3_MAX_OPEN_RISK_PERCENT=1.50
V14_3_MAX_OPEN_POSITIONS=5
V14_3_DAILY_LOSS_LIMIT_PERCENT=4.00
V14_3_LIVE_HARD_DD_PERCENT=6.00
V14_3_MAX_SIGNAL_AGE_MINUTES=90
V14_3_MAX_DEVIATION_POINTS=10

# Keep both false during READ_ONLY and initial APPROVAL testing.
V14_3_FORWARD_GATE_PASSED=false
V14_3_ALLOW_DEMO_AUTO=false

V14_3_MAX_SPREAD_GBPUSD=2.0
V14_3_MAX_SPREAD_EURUSD=1.5
V14_3_MAX_SPREAD_GBPJPY=3.0
V14_3_MAX_SPREAD_AUDUSD=1.8
V14_3_MAX_SPREAD_USDJPY=2.0

V14_3_LIVE_STATE_PATH=state/v14_3_satellite_live_state.json

# Optional exact GBPUSD/GBPJPY V14.3 signal provider. The module must expose
# build_live_signals(client). Leave this name only when v14_3_signals.py exists.
V14_3_LEGACY_GBP_ICT_PROVIDER=v14_3_signals
