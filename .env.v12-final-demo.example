# V12 FINAL $3,201.58 AUTOMATIC DEMO PROFILE
# Copy to .env only for the dedicated named-engine demo adapter.
# The immutable portfolio limits live in mt5_ai_bridge/v12_final_risk.py.

MT5_LOGIN=00000000
MT5_PASSWORD=your-password
MT5_SERVER=YourBroker-Server

# Mandatory. The executor additionally verifies MT5 account.trade_mode is DEMO.
MODE=AUTO
V12_FINAL_PROFILE=V12_FINAL_3201_58
V12_FINAL_STATE_PATH=v12_final_research_state.json
V12_FINAL_ACCOUNT_MODE_PATH=v12_final_account_mode.json
V12_FINAL_MAX_DEVIATION_POINTS=10

# Exact research portfolio ceilings (documentation only; code is authoritative)
V12_FINAL_MAX_POSITIONS=5
V12_FINAL_MAX_OPEN_RISK_PERCENT=1.50
V12_FINAL_PRECISION_SYMBOL_CAP_PERCENT=0.75
V12_FINAL_LEGACY_SYMBOL_CAP_PERCENT=0.75
V12_FINAL_NEW_SYMBOL_CAP_PERCENT=0.25
V12_FINAL_ALIGNED_GBP_CAP_PERCENT=0.90
V12_FINAL_MIXED_GBP_CAP_PERCENT=0.65

# Research safety overlays
V12_FINAL_DAILY_DRAWDOWN_PERCENT=1.50
V12_FINAL_TOTAL_DRAWDOWN_PERCENT=5.00
V12_FINAL_DUPLICATE_WINDOW_SECONDS=300
V12_FINAL_MAX_SPREAD_GBPUSD=2.0
V12_FINAL_MAX_SPREAD_EURUSD=2.0
V12_FINAL_MAX_SPREAD_GBPJPY=4.0
V12_FINAL_MAX_SPREAD_AUDUSD=2.5
V12_FINAL_MAX_SPREAD_USDJPY=2.5

LOG_LEVEL=INFO
DB_PATH=journal.db
