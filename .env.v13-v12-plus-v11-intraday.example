# V13 V12 Final + V11 Intraday research profile
# Merge these values into your existing .env while preserving private MT5 credentials.

STRATEGY_PROFILE=V13_V12_FINAL_PLUS_V11_INTRADAY_RESEARCH
MODE=READ_ONLY
ALLOW_BROKER_ORDER_API=false
REQUIRE_HUMAN_REVIEW=true

# V12 Final remains the master risk governor.
V12_FINAL_CONTROLS_ENABLED=true
V12_MAX_OPEN_POSITIONS=5
V12_MAX_OPEN_RISK_PERCENT=1.50
V12_PRECISION_SYMBOL_CAP_PERCENT=0.75
V12_LEGACY_SYMBOL_CAP_PERCENT=0.75
V12_NEW_SYMBOL_CAP_PERCENT=0.25
V12_ALIGNED_GBP_CAP_PERCENT=0.90
V12_MIXED_GBP_CAP_PERCENT=0.65

# V11 intraday/day-trading extension.
V11_INTRADAY_EXTENSION_ENABLED=true
V11_ALLOW_OVERNIGHT_POSITIONS=false
V11_FORCE_FLAT_HOUR_UTC=20
ENABLE_GBPUSD_V11_INTRADAY=true
ENABLE_EURUSD_V11_INTRADAY=true
ENABLE_GBPJPY_V11_INTRADAY=true
DISABLE_V11_SWING_ENGINES=true

# V11 intraday risk tiers are proposals only; V12/V13 must approve final risk.
GBPUSD_V11_INTRADAY_RISK_TIERS=0.30,0.35,0.40
EURUSD_V11_INTRADAY_RISK_TIERS=0.30,0.35,0.40
GBPJPY_V11_INTRADAY_RISK_TIERS=0.25,0.35,0.40

# Research output paths.
V13_BACKTEST_REPORT=research/V13_V12_FINAL_PLUS_V11_INTRADAY_BACKTEST_REPORT.md
V13_BACKTEST_JSON=research/v13_v12_plus_v11_intraday_backtest_results.json
